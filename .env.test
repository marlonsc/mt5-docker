# Test container settings (avoid port conflicts with production)
# Credentials are read from .env file (do NOT duplicate here)

MT5DOCKER_TEST_CONTAINER_NAME=mt5docker-test
MT5DOCKER_TEST_GRPC_PORT=48812
MT5DOCKER_TEST_HEALTH_PORT=48002
MT5DOCKER_TEST_VNC_PORT=43000
MT5DOCKER_TEST_VOLUME_NAME=mt5docker-test-data
MT5DOCKER_TEST_NETWORK_NAME=mt5docker-test-network
